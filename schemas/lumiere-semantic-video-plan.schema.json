{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumiere.local/schemas/lumiere-semantic-video-plan.schema.json",
  "title": "Lumiere Semantic Video Plan",
  "description": "Semantisches Planformat fuer generatorbasierte Remotion-Skripte mit getrennter Source-Time und Plan-Time.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion",
    "id",
    "version",
    "title",
    "source",
    "chapters"
  ],
  "properties": {
    "planVersion": {
      "type": "string",
      "description": "Version des Planformats.",
      "examples": [
        "1.0"
      ]
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "number"
        }
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "scenarioPath": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        }
      }
    },
    "source": {
      "$ref": "#/$defs/SourceVideo"
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Chapter"
      }
    }
  },
  "$defs": {
    "SourceVideo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "videoPath",
        "fps",
        "width",
        "height"
      ],
      "properties": {
        "videoPath": {
          "type": "string",
          "minLength": 1
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "steps"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "didactics": {
          "$ref": "#/$defs/Didactics"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Step"
          }
        }
      }
    },
    "Step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "clip"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "clip": {
          "$ref": "#/$defs/Clip"
        },
        "freezes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Freeze"
          }
        },
        "pauses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Pause"
          }
        },
        "narrations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Narration"
          }
        },
        "callouts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Callout"
          }
        },
        "clickMarkers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ClickMarker"
          }
        }
      }
    },
    "Didactics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "purpose": {
          "$ref": "#/$defs/TextLeaf"
        },
        "explanation": {
          "$ref": "#/$defs/TextLeaf"
        },
        "consequence": {
          "$ref": "#/$defs/TextLeaf"
        }
      }
    },
    "TextLeaf": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceStartMs",
        "sourceEndMs"
      ],
      "properties": {
        "sourceStartMs": {
          "type": "integer",
          "minimum": 0
        },
        "sourceEndMs": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Freeze": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atSourceMs",
        "durationMs"
      ],
      "properties": {
        "atSourceMs": {
          "type": "integer",
          "minimum": 0
        },
        "durationMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "Pause": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atSourceMs",
        "durationMs"
      ],
      "properties": {
        "atSourceMs": {
          "type": "integer",
          "minimum": 0
        },
        "durationMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "Narration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "file"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "atMs": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "channel": {
          "type": "string"
        }
      }
    },
    "Callout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "atMs": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "durationMs": {
          "type": "integer",
          "minimum": 1,
          "default": 1200
        },
        "variant": {
          "type": "string",
          "enum": [
            "default",
            "chapter-card"
          ],
          "default": "default"
        },
        "fontSize": {
          "type": "integer",
          "minimum": 1
        },
        "textYStart": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "lineSpacing": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "position": {
          "type": "string",
          "enum": [
            "top-left",
            "top-right",
            "bottom-left",
            "bottom-right",
            "center"
          ],
          "default": "bottom-right"
        }
      }
    },
    "ClickMarker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atSourceMs",
        "x",
        "y"
      ],
      "properties": {
        "atSourceMs": {
          "type": "integer",
          "minimum": 0
        },
        "x": {
          "type": "number",
          "minimum": 0
        },
        "y": {
          "type": "number",
          "minimum": 0
        },
        "durationMs": {
          "type": "integer",
          "minimum": 1,
          "default": 900
        }
      }
    }
  }
}
