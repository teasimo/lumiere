<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript id="sus-filter-vorname-nachname" szenario-version="1.0" status="Entwurf" neo-version-min="6.0" titel="Fragment: SuS nach Vorname und Nachname filtern" fragment="true">

	<Variablen>
		<Variable name="nachname"/>
		<Variable name="vorname"/>
	</Variablen>

	<Gruppe >

		<Click data-id="filters"/>
		<Wenn data-id="filters/basic/choose" text="Vornamen" status="nicht-sichtbar">
			<Anzeige data-id="filters/basic/choose" text="Vornamen"/>
		</Wenn>
		<!-- das ist ggf. stabiler: -->
		<!-- <Click data-id="filters/basic/choose" /> -->
		<!-- <Click data-id="filters/basic/choose/vornamen" /> -->
		<Auswahl data-id="filters/basic/choose" text="Vornamen"/>
		<Eingabe data-id="filters/basic/1" text="{{vorname}}"/>
		
		<Click data-id="filters/basic/choose" />
		<Click data-id="filters/basic/choose/familienname"/>
		<Eingabe data-id="filters/basic/2" text="{{nachname}}"/>
		<Click data-id="filters/apply"/>

	</Gruppe>
</SzenarioScript>