<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript
    id="call-action"
    szenario-version="1.0"
    status="Entwurf"
    neo-version-min="6.0"
    titel="Fragment: Aktion aufrufen"
    fragment="true">

    <Variablen>
        <Variable name="action-label"/>
    </Variablen>

    <Gruppe id="call_action">

        <Click
            id="controlBtn_actions"
            data-id="controlBtn/actions"/>

        <Click
            id="action_auswaehlen"
            text="{{action-label}}"/>

    </Gruppe>

</SzenarioScript>