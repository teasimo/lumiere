<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript id="neo-login" szenario-version="1.0" status="Freigegeben" neo-version-min="6.0" titel="Fragment: NEO Login" fragment="true">

	<Notizen>
		Geprüft:
		-  Der normale Login
		Nicht Geprüft:
		- Der Organsationskontext
	</Notizen>

	<Variablen>
		<Variable name="url"/>
		<Variable name="username"/>
		<Variable name="password"/>
	</Variablen>

	<Gruppe>

		<Oeffnen url="{{url}}"/>

		<Eingabe data-id="login/input/user">{{username}}</Eingabe>
		<Eingabe data-id="login/input/pass">{{password}}</Eingabe>
		<Click data-id="login/button/submit"/>
		<Wenn data-id="login/confirm-organization-dialog" status="sichtbar">
			<Click id="confirm-organization-click" data-id="login/context/button/submit"/>
			<Warten id="confirm-organization-erwartung" data-id="logo" status="sichtbar"/>
		</Wenn>

	</Gruppe>

</SzenarioScript>