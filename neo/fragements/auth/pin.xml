<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript id="pin" szenario-version="1.0" status="Freigegeben" neo-version-min="6.0" titel="Fragment: PIN bestätigen" fragment="true">

    <Notizen>
		Geprüft:
		-  Pin eingabe
		Nicht Geprüft:
		- Pin eingabe ignorieren
    </Notizen>


    <Variablen>
        <Variable name="pin"/>
    </Variablen>

    <Gruppe>

        <Wenn data-id="pin-erforderlich/input/pin" status="sichtbar" timeout-ms="1500">
            <Eingabe data-id="pin-erforderlich/input/pin" text="{{pin}}"/>
            <Click data-id="pin-erforderlich/button/continue"/>

            <Sonst>
                <!-- Ohne PN bleibt das Hauptmenü beim Navigieren offen -->
                <Click data-id="button/menu-toggle"/>
            </Sonst>
        </Wenn>     

</Gruppe>

</SzenarioScript>