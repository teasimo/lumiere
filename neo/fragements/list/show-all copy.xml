<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript
    id="list-show-all"
    szenario-version="1.0"
    status="Entwurf"
    neo-version-min="6.0"
    titel="Fragment: Alle Listeneinträge anzeigen"
    fragment="true">

    <Gruppe id="list_show_all">

        <Wenn
            id="controlBtn_pagesize_visible"
            data-id="controlBtn/pagesize"
            status="sichtbar">

            <Click
                id="controlBtn_pagesize"
                data-id="controlBtn/pagesize"/>

            <Click
                id="controlBtn_pagesize_option_0"
                data-id="controlBtn/pagesize/option/0"/>

        </Wenn>

    </Gruppe>

</SzenarioScript>