<?xml version='1.0' encoding='UTF-8'?>
<SzenarioScript id="sus-dublette-zusammenfuehren" szenario-version="1.0" status="Entwurf" neo-version-min="6.0" titel="Schüler*innen-Datensätze zusammenführen">
  <Einstellungen>    
    <Gruppe name="video">
      <Einstellung name="autoscroll_smooth" value="True"/>
      <Einstellung name="wait_between_steps" value="1000"/>
      <Gruppe name="resolution">
        <Einstellung name="width" value="1280"/>
        <Einstellung name="height" value="720"/>
      </Gruppe>
    </Gruppe>
    <Gruppe name="presentation">
      <Gruppe name="indicators">
        <Gruppe name="click">
          <Einstellung name="enabled" value="True"/>
          <Einstellung name="before_ms" value="800"/>
          <Einstellung name="after_ms" value="100"/>
          <Einstellung name="fade_ms" value="50"/>
        </Gruppe>
      </Gruppe>
    </Gruppe>
  </Einstellungen>
  <Daten>
    <Datensatz name="runtime">
      <Wert name="base_url" value="https://neo-test.de"/>
    </Datensatz>
    <Wert name="random" value="{{randomNumber()}}"/>
    <Datensatz name="actor">
      <Wert name="username" value="schule_05320_schulleitung"/>
      <Wert name="password" value="!Neo-2405Neo!"/>
    </Datensatz>
    <Datensatz name="schueler">
      <Wert name="vorname" value="Mark {{random}}"/>
      <Wert name="nachname" value="Mustermann {{random}}"/>
      <Wert name="geburtsdatum" value="01.01.2020"/>
      <Wert name="geburtsort" value="Musterstadt"/>
      <Wert name="adresseSuche" value="Osterfeld 2 Emmerke"/>
    </Datensatz>
    <Datensatz name="schueler.ez1">
      <Wert name="anrede" value="Frau"/>
      <Wert name="vorname" value="Laura"/>
      <Wert name="nachname" value="Mustermann"/>
      <Wert name="geburtsdatum" value="01.01.1975"/>
      <Wert name="geburtsort" value="Musterstadt"/>
      <Wert name="adresseSuche" value="Osterfeld 2 Emmerke"/>
    </Datensatz>
    <Datensatz name="schueler.ez2">
      <Wert name="anrede" value="Herr"/>
      <Wert name="vorname" value="Niklas"/>
      <Wert name="nachname" value="Mustermann"/>
      <Wert name="geburtsdatum" value="01.01.1970"/>
      <Wert name="geburtsort" value="Musterstadt"/>
      <Wert name="adresseSuche" value="Osterfeld 2 Emmerke"/>
    </Datensatz>
  </Daten>
  <Variablen>
    <Variable name="random"/>
  </Variablen>

  <!-- Vorbereitung -->
  <Gruppe>
    <!-- Login -->
    <Fragment name="neo-login">
      <Parameter name="url" value="{{runtime.base_url}}"/>
      <Parameter name="username" value="{{actor.username}}"/>
      <Parameter name="password" value="{{actor.password}}"/>
    </Fragment>

    <!-- Dubletten anlegen -->
    <Fragment name="meldedaten-create">
      <Parameter name="schueler.nachname" value="{{schueler.nachname}}"/>
      <Parameter name="schueler.vorname" value="{{schueler.vorname}}"/>
      <Parameter name="schueler.geburtsdatum" value="{{schueler.geburtsdatum}}"/>
      <Parameter name="schueler.geburtsort" value="{{schueler.geburtsort}}"/>
      <Parameter name="schueler.adresseSuche" value="{{schueler.adresseSuche}}"/>
      <Parameter name="schueler.ez1.nachname" value="{{schueler.ez1.nachname}}"/>
      <Parameter name="schueler.ez1.vorname" value="{{schueler.ez1.vorname}}"/>
      <Parameter name="schueler.ez1.anrede" value="{{schueler.ez1.anrede}}"/>
      <Parameter name="schueler.ez1.adresseSuche" value="{{schueler.ez1.adresseSuche}}"/>
      <Parameter name="schueler.ez2.nachname" value="{{schueler.ez2.nachname}}"/>
      <Parameter name="schueler.ez2.vorname" value="{{schueler.ez2.vorname}}"/>
      <Parameter name="schueler.ez2.anrede" value="{{schueler.ez2.anrede}}"/>
      <Parameter name="schueler.ez2.adresseSuche" value="{{schueler.ez2.adresseSuche}}"/>
    </Fragment>
    <Fragment name="meldedaten-create">
      <Parameter name="schueler.nachname" value="{{schueler.nachname}}"/>
      <Parameter name="schueler.vorname" value="{{schueler.vorname}}"/>
      <Parameter name="schueler.geburtsdatum" value="{{schueler.geburtsdatum}}"/>
      <Parameter name="schueler.geburtsort" value="{{schueler.geburtsort}}"/>
      <Parameter name="schueler.adresseSuche" value="{{schueler.adresseSuche}}"/>
      <Parameter name="schueler.ez1.nachname" value="{{schueler.ez1.nachname}}"/>
      <Parameter name="schueler.ez1.vorname" value="{{schueler.ez1.vorname}}"/>
      <Parameter name="schueler.ez1.anrede" value="{{schueler.ez1.anrede}}"/>
      <Parameter name="schueler.ez1.adresseSuche" value="{{schueler.ez1.adresseSuche}}"/>
      <Parameter name="schueler.ez2.nachname" value="{{schueler.ez2.nachname}}"/>
      <Parameter name="schueler.ez2.vorname" value="{{schueler.ez2.vorname}}"/>
      <Parameter name="schueler.ez2.anrede" value="{{schueler.ez2.anrede}}"/>
      <Parameter name="schueler.ez2.adresseSuche" value="{{schueler.ez2.adresseSuche}}"/>
    </Fragment>
    <!-- Duplikat bestätigen -->
    <Click text="Ja"/>

    <!-- Alle Meldedatensätze zu SuS machen -->
    <Fragment name="neo-hauptmenue-sus-meldedaten"/>
    <Click data-id="filters"/>
    <Click data-id="filters/basic/choose"/>
    <Click data-id="filters/basic/choose/haserst"/>
    <Click data-id="filters/apply"/>
    <Fragment name="list-show-all"/>
    <Click data-id="controlBtn/actions"/>
    <Click aria-label="Mehrfachauswahl"/>
    <Click data-id="@root/btn/action-CommonSelectAllAction"/>
    <Fragment name="call-action">
      <Parameter name="action-label" value="Aufforderung zur Schulanmeldung (Nur Verknüpfungscode)"/>
    </Fragment>
    <Click text="Ja"/>
    <Fragment name="neo-hauptmenue-sus-schuelerinnen"/>

    <!-- Zur Startseite -->
    <Fragment name="neo-hauptmenue-home"/>
  </Gruppe>



  <!-- Szenario -->
  <Gruppe>
    <VideoStart/>

    <!-- Intro -->
    <Folie>Schüler*innen-Datensätze zusammenführen</Folie>
    <Info typ="Erklärung">Folgende Funktionalität ermöglicht Ihnen das Zusammenführen von doppelten Schüler*innen-Datensätzen.</Info>
    <Folie>Zweck: Ein Datensatz pro Schüler*in</Folie>
    <Info typ="Erklärung">In NEO Niedersachsen sollte für jede Schüler*in immer nur genau ein Datensatz vorliegen, um keine widersprüchlichen Daten zu erzeugen. Ist dies nicht der Fall, sollte man die Daten der verschiedenen Datensätze zusammenführen.</Info>
    <Folie>Zweck: Ein Datensatz pro Schüler*in
Auslöser: Immer nutzbar</Folie>
    <Info typ="Erklärung">Diese Funktionalität ist zu jedem Zeitpunkt in NEO Niedersachsen nutzbar.</Info>
    <Folie>Zweck: Ein Datensatz pro Schüler*in
Auslöser: Immer nutzbar
Berechtigung: Datenpflege der Funktion Schulleitung</Folie>
    <Info typ="Erklärung">Sie benötigen für diese Funktionalität die Berechtigung mit dem Namen - Datenpflege -, die in der Funktion - Schulleitung - enthalten ist.</Info>
    <Folie>Zweck: Ein Datensatz pro Schüler*in
Auslöser: Immer nutzbar
Berechtigung: Datenpflege der Funktion Schulleitung
Wirkung: Datenübernahme und Vormerkung zur Löschung</Folie>
    <Info typ="Erklärung">Das Ergebnis ist, dass bei Bedarf Daten aus dem nachrangigen Datensatz in den führenden Datensatz übernommen wurden und der nachrangige Datensatz ausgeblendet und für die Löschung vorgemerkt ist.</Info>


    <!-- Ausgangslage -->
    <Fragment name="neo-hauptmenue-sus-schuelerinnen"/>

    <Fragment name="sus-filter-vorname-nachname">
      <Parameter name="vorname" value="{{schueler.vorname}}"/>
      <Parameter name="nachname" value="{{schueler.nachname}}"/>
    </Fragment>

    <Info typ="Erklärung">In diesem Beispiel liegen zwei Datensätze für die gleiche Person vor.</Info>

    <!-- Umgang -->

    <!-- 1) Führenden Datensatz öffnen -->
    <Info typ="Zweck">Um den nachrangigen Datensatz aufzulösen, muss der führende Datensatz geöffnet werden.</Info>
    <Click data-id="controlBtn/action-detaillink"/>
    <Click text="Einstellungen"/>
    <!-- 2) Nachrangigen Datensatz identifizieren -->
    <Click data-id="btn_container/btn_container~1/link_schueler_dublette"/>
    <Info typ="Erklärung">Hier kann ein nachrangiger Datensatz identifiziert werden. Der Auswahldialog filtert in den Voreinstellungen auf die in NEO Niedersachsen üblichen Merkmale zur Identifikation doppelter Datensätze. Dies sind - Vorname, Nachname, Geburtsort und Geburtsdatum. Diese Angaben des aktuell geöffneten Datensatzes werden automatisch im Dialog als Filter gesetzt, um die Identifikation von Dubletten zu unterstützen.</Info>
    <Click aria-label="{{schueler.nachname}}, {{schueler.vorname}} markieren"/>
    <Click data-id="btn_container/btn_container~1/link_schueler_dublette/uebernehmen"/>
    <Info typ="Erklärung">Identifizierte Dubletten können nun im Folgeschritt mit dem führenden Datensatz zusammengeführt werden.</Info>
    <Click data-id="g_linked/$data0/verschmelzen-btn"/>

    <!-- 3) Nachrangigen Datensatz zusammenführen -->
    <Click data-id="g_action_btns/g_content/btn_merge"/>
    <Info typ="Konsequenz">Die ausgewählten Daten des nachrangigen Datensatzes wurden nun übernommen und der nun nicht weiter gebrauchte nachrangige Datensatz wird zur Löschung vorgemerkt.</Info>
    <Click text="Ja"/>
    <Info typ="Erklärung">Der nachrangige Datensatz, der in den führenden Datensatz übernommen wurde, ist in der Standard-Filterung nun ausgeblendet.</Info>
    <Fragment name="neo-hauptmenue-sus-schuelerinnen"/>
    <Info typ="Zweck">Die als nachrangig markierten sowie die bereits aufgelösten Datensätze können in der Liste der Schüler*innen bis zur Löschung weiterhin eingesehen werden.</Info>
    <Info typ="Erklärung">Hierzu muss die Standard-Filterung angepasst werden, dass diese angezeigt werden.</Info>

    <!-- 4) Aufgelöste Datensätze anzeigen -->
    <Click data-id="filters"/>
    <Click data-id="filters/basic/0" aria-label="Schüler*in-Markierung"/>
    <Click data-id="markierung/markierung/option/16" text="Dublette (verschmolzen)"/>
    <Click data-id="markierung/markierung/option/0"/>
    <Click data-id="markierung/markierung/option/8"/>
    <Click data-id="markierung/markierung/option/1" text="Dublette"/>
    <Click data-id="filters/apply"/>

    <VideoStop/>
  </Gruppe>



  

</SzenarioScript>