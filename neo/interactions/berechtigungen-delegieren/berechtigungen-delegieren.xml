<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript id="berechtigungen-delegieren" szenario-version="1.0" status="Entwurf" neo-version-min="6.0" titel="Berechtigungen delegieren">

	<Einstellungen>
		<Gruppe name="video">
			<Einstellung name="autoscroll_smooth" value="false"/>
			<Einstellung name="wait_between_steps" value="1000"/>
			<Gruppe name="resolution">
				<Einstellung name="width" value="1280"/>
				<Einstellung name="height" value="720"/>
			</Gruppe>
		</Gruppe>
		<Gruppe name="presentation">
			<Gruppe name="indicators">
				<Gruppe name="click">
					<Einstellung name="enabled" value="true"/>
					<Einstellung name="before_ms" value="100"/>
					<Einstellung name="after_ms" value="100"/>
					<Einstellung name="fade_ms" value="50"/>
				</Gruppe>
			</Gruppe>
		</Gruppe>
	</Einstellungen>

	<Daten>
		<Datensatz name="runtime">
			<Wert name="base_url" value="https://neo-test.de"/>
		</Datensatz>
		<Datensatz name="actor">
			<Wert name="username" value="schule_05320_schulleitung"/>
			<Wert name="password" value="!Neo-2405Neo!"/>
		</Datensatz>
		<Datensatz name="personal">
			<Wert name="vorname" value="Cheryl"/>
			<Wert name="nachname" value="Edwards"/>
		</Datensatz>
	</Daten>

	<Gruppe>

		<Fragment name="neo-login">
			<Parameter name="username" value="{{actor.username}}"/>
			<Parameter name="password" value="{{actor.password}}"/>
		</Fragment>

		<Gruppe>
			<Fragment name="neo-hauptmenue-personal-personalverwaltung"/>

			<Fragment name="meldedaten-filter-vorname-nachname">
				<Parameter name="vorname" value="{{personal.vorname}}"/>
				<Parameter name="nachname" value="{{personal.nachname}}"/>
			</Fragment>

			<Fragment name="element-open-first"/>

			<Click text="Einstellungen"/>
		</Gruppe>

		<Gruppe id="navigate_mein_profil">
			<VideoStart/>
			<Info typ="Zweck" ausgabe="gruppe">
                Datenqualität ist in der Verwaltung sehr wichtig, um immer auf Basis der richtigen Informationen zu entscheiden. Wichtig hierfür ist, dass pro Schüler*in immer genau nur ein Datensatz mit allen bekannten Informationen vorliegt.
                Daher zeigen wir Ihnen im zum Einen wie NEO Niedersachsen Sie dabei unterstützt, dass keine doppelten Datensätze angelegt werden. Zum anderen wird Ihnen demonstriert, wie doppelte Datensätze, die dennoch entstanden sind, zu einem Datensatz zusammengeführt werden können.
			</Info>
			<Info typ="Erklärung" ausgabe="gruppe">
                Es gibt für Schüler zwei Stellen an denen Schüler-Datensätze entstehen können. Dies ist zum einen der Bereich der Meldedaten.
			</Info>
			<Fragment name="neo-hauptmenue-mein-profil"/>
		</Gruppe>

		<Wenn data-id="g_prp_org_delegate/btn/action-insert-scope" status="nicht-sichtbar">
			<Click  data-id="btn/action-expandcollapseall"/>
		</Wenn>

		<Click text="Einstellungen"/>

		<Click data-id="g_prp_org_delegate/btn/action-insert-scope"/>

		<Auswahl data-id="g_prp_org_delegate/$data0/funktion_anzeige" text="Schulleitung"/>

		<Auswahl data-id="g_prp_org_delegate/$data0/prp_name" text="Meldedatenimport"/>

		<Auswahl data-id="g_prp_org_delegate/$data0/empfaenger_display_name" text="{{personal.nachname}}, {{personal.vorname}}"/>

		<Eingabe data-id="g_prp_org_delegate/$data0/bbo_wirksam_ab" text="07.06.2026"/>

		<Eingabe data-id="g_prp_org_delegate/$data0/bbo_wirksam_bis" text="15.06.2026"/>

		<Click data-id="btn/action-save"/>

		<Click text="Ja"/>

		<Click data-id="g_prp_org_delegate/$data0/prp_name"/>

		<Click text="Ja"/>

	</Gruppe>
</SzenarioScript>