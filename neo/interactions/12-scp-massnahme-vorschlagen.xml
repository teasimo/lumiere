<?xml version='1.0' encoding='UTF-8'?>
<SzenarioScript lunettes-id="12" id="scp-massnahme-vorschlagen" szenario-version="1.0" neo-version-min="6.0">
  <Daten>
    <Datensatz name="runtime">
      <Wert name="base_url" value="https://neo-integration.de"/>
    </Datensatz>
    <Wert name="random" value="{{randomNumber()}}"/>
    <Datensatz name="actor">
      <Wert name="username" value="schule_05320_schulleitung"/>
      <Wert name="password" value="!Neo-2405Neo!"/>
    </Datensatz>
  </Daten>
  <Variablen>
    <Variable name="random"/>
  </Variablen>

  <!-- Vorbereitung -->
  <Gruppe>


    <VideoStart/>

    <!-- Login -->
    <Fragment name="neo-login">
      <Parameter name="url" value="{{runtime.base_url}}"/>
      <Parameter name="username" value="{{actor.username}}"/>
      <Parameter name="password" value="{{actor.password}}"/>
    </Fragment>

    <Click data-id="g_massnahmenuebersicht/p_scp_massnahmeuebersicht_panel/massnahme_create_btn"/>
    <Click data-id="g_scp_allgemeine/g_allgemeine_beschreibung/zieldermassnahme"></Eingabe>
    <Click data-id="g_scp_allgemeine/g_allgemeine_beschreibung/zieldermassnahme/option/1709_001"/>
    <Click data-id="g_scp_allgemeine/g_allgemeine_beschreibung/zielvereinbarung"></Eingabe>
    <!-- Hier braucht es eine relative Auswahl: z.B. 1. Element   -->
    <Click data-id="g_scp_allgemeine/g_allgemeine_beschreibung/zielvereinbarung/option/2f4bf12c-654a-6343-2f0c-575b61c5842a"/>

    <Eingabe data-id="g_scp_beschreibung/g_scp_beschreibung~1/kurzbezeichnung">Nette Maßnahme</Eingabe>
    <Eingabe data-id="g_scp_beschreibung/g_scp_beschreibung~1/durchfuehrung_von">09.06.2026</Eingabe>
    <Eingabe data-id="g_scp_beschreibung/g_scp_beschreibung~1/durchfuehrung_bis">20.07.2026</Eingabe>
    <Eingabe data-id="g_scp_beschreibung/g_scp_beschreibung~1/massnahme_beschreibung">Die maßnahme hat dieses und jenes vor</Eingabe>
    <Click data-id="btn/action-save"/>
    <Click data-id="controlBtn/actions"/>
    <Click text="Maßnahme vorschlagen"/>

    <!-- Maßnahme vorschlagen?  -->
    <Click text="Ja"/>

  </Gruppe>
</SzenarioScript>