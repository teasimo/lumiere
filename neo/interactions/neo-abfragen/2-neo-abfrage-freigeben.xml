<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript lunettes-id="2" id="neo-abfrage-freigeben" testscript-version="1" videoscript-version="1"  neo-version-min="6.0" neo-version-max="7.0" titel="NEO Abfrage freigeben">

	<Einstellungen>
		<Gruppe name="video">
			<Einstellung name="autoscroll_smooth" value="false"/>
			<Einstellung name="wait_between_steps" value="1000"/>
			<Gruppe name="resolution">
				<Einstellung name="width" value="1280"/>
				<Einstellung name="height" value="720"/>
			</Gruppe>
		</Gruppe>
		<Gruppe name="presentation">
			<Gruppe name="indicators">
				<Gruppe name="click">
					<Einstellung name="enabled" value="true"/>
					<Einstellung name="before_ms" value="100"/>
					<Einstellung name="after_ms" value="100"/>
					<Einstellung name="fade_ms" value="50"/>
				</Gruppe>
			</Gruppe>
		</Gruppe>
	</Einstellungen>

	<Daten>
		<Datensatz name="runtime">
			<Wert name="base_url" value="https://neo-test.de"/>
		</Datensatz>
		<Datensatz name="actor">
			<Wert name="username" value="ealles"/>
			<Wert name="password" value="!Neo-2405Neo!"/>
		</Datensatz>
	</Daten>

	<Gruppe>

		<Fragment name="neo-login">
			<Parameter name="url" value="{{runtime.base_url}}"/>
			<Parameter name="username" value="{{actor.username}}"/>
			<Parameter name="password" value="{{actor.password}}"/>
		</Fragment>
		<!-- Organisationsauswahl nach dem Login -->
		<Click id="confirm-organization-click" data-id="login/context/button/submit"/>
	</Gruppe>
	<Gruppe>
		<VideoStart/>
		<Kapitel>NEO Abfrage freigeben</Kapitel>
		<Schritt>NEO Abfragen öffnen</Schritt>
		<Click data-id="button/menu-toggle"/>
		<Click data-id="menu/item/erhebungen/"/>
		<Click data-id="menu/link/erhebungen/neo-abfrage/"/>

		<Schritt>Freizugegebende Abfragen filtern</Schritt>
		<Click data-id="filters"/>
		<Click data-id="filters/basic/choose"/>		
		<Click data-id="filters/basic/choose/status_adhoc_abfrage"/>
		<Click data-id="filters/basic/0"/>
		<Click data-id="status_adhoc_abfrage/status_adhoc_abfrage/option/1400_03"/>
		<!-- Damit das Dropdown geschlossen wird -->
		<Click data-id="filters/basic/0"/>
		<Click data-id="filters/apply"/>

		<Schritt>Abfrage auswählen</Schritt>
		<!-- erstes Element öffnen -->
		<Click data-id="list-item/0/toggleDetails"/>
		<Click data-id="controlBtn/action-detaillinkwtitle"/>

		<!-- Freigeben -->
		<Schritt>Abfrage freigeben</Schritt>
		<Click data-id="controlBtn/actions"/>
		<Click text="Abfrage an Moderation weitergeben"/>
		<Click text="Ja"/>

		<VideoStop/>
	</Gruppe>
</SzenarioScript>
