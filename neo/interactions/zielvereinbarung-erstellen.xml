<?xml version='1.0' encoding='UTF-8'?>
<SzenarioScript id="zielvereinbarung-erstellen" szenario-version="1.0" status="Entwurf" neo-version-min="6.0" titel="Schüler*innen-Datensätze zusammenführen">
	<Einstellungen>
		<Gruppe name="video">
			<Einstellung name="autoscroll_smooth" value="True"/>
			<Einstellung name="wait_between_steps" value="1000"/>
			<Gruppe name="resolution">
				<Einstellung name="width" value="1280"/>
				<Einstellung name="height" value="720"/>
			</Gruppe>
		</Gruppe>
		<Gruppe name="presentation">
			<Gruppe name="indicators">
				<Gruppe name="click">
					<Einstellung name="enabled" value="True"/>
					<Einstellung name="before_ms" value="800"/>
					<Einstellung name="after_ms" value="100"/>
					<Einstellung name="fade_ms" value="50"/>
				</Gruppe>
			</Gruppe>
		</Gruppe>
	</Einstellungen>
	<Daten>
		<Datensatz name="runtime">
			<Wert name="base_url" value="https://neo-integration.de"/>
		</Datensatz>
		<Wert name="random" value="{{randomNumber()}}"/>
		<Datensatz name="actor">
			<Wert name="username" value="schule_05320_schulleitung"/>
			<Wert name="password" value="!Neo-2405Neo!"/>
		</Datensatz>		
	</Daten>
	<Variablen>
		<Variable name="random"/>
	</Variablen>

	<!-- Vorbereitung -->
	<Gruppe>
		<VideoStart/>
		<Kapitel>Zielvereinbarung erstellen</Kapitel>
		<Schritt>Einloggen</Schritt>
		<!-- Login -->
		<Fragment name="neo-login">
			<Parameter name="url" value="{{runtime.base_url}}"/>
			<Parameter name="username" value="{{actor.username}}"/>
			<Parameter name="password" value="{{actor.password}}"/>
		</Fragment>

		<Info typ="Erklärung">Damit man im Start-Chancen-Programm Geld ausgeben kann, muss man eine Zielvereinbarung erstellen.</Info>

		<Schritt>Start-Chancen-Programm öffnen</Schritt>
		<Click data-id="button/menu-toggle"/>
		<Click data-id="menu/item/startchancen-programm/"/>
		<Click data-id="menu/link/startchancen-programm/meine-uebersicht/"/>
		
		<Schritt>Zielvereinbarung erfassen</Schritt>
		<Click data-id="g_scp_zvb/btn/action-createScpSchuleZvb"/>
		<Eingabe data-id="g_scp_zvb/$data0/titel">Neues Ziel {{random}}</Eingabe>		
		<Eingabe data-id="g_scp_zvb/$data0/beschlossen_am">09.01.2026</Eingabe>
		
		<Upload data-id="g_scp_zvb/$data0/file_zielvereinbarung">pdfdummy.pdf</Upload>
		<Click data-id="btn/action-save"/>
		<VideoStop/>
	</Gruppe>
</SzenarioScript>