<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript id="zugangskonto-erstellen" testscript-version="1" videoscript-version="1" confluence-page-id="2103279620" status="Entwurf" neo-version-min="6.0" neo-version-max="7.0" titel="Zugangskonto erstellen">


	<Einstellungen>
		<Gruppe name="video">
			<Einstellung name="autoscroll_smooth" value="false"/>
			<Einstellung name="wait_between_steps" value="1000"/>
			<Gruppe name="resolution">
				<Einstellung name="width" value="1280"/>
				<Einstellung name="height" value="720"/>
			</Gruppe>
		</Gruppe>
		<Gruppe name="presentation">
			<Gruppe name="indicators">
				<Gruppe name="click">
					<Einstellung name="enabled" value="true"/>
					<Einstellung name="before_ms" value="100"/>
					<Einstellung name="after_ms" value="100"/>
					<Einstellung name="fade_ms" value="50"/>
				</Gruppe>
			</Gruppe>
		</Gruppe>
	</Einstellungen>

	<Daten>
		<Datensatz name="runtime">
			<Wert name="base_url" value="https://neo-test.de"/>
		</Datensatz>
		<Datensatz name="actor">
			<Wert name="username" value="schule_05320_schulleitung"/>
			<Wert name="password" value="!Neo-2405Neo!"/>
		</Datensatz>
	</Daten>

	<Gruppe>

		<Fragment name="neo-login">
			<Parameter name="url" value="{{runtime.base_url}}"/>
			<Parameter name="username" value="{{actor.username}}"/>
			<Parameter name="password" value="{{actor.password}}"/>
		</Fragment>
	</Gruppe>
	<Gruppe>
		<VideoStart/>
		<Info typ="Erklärung">Personen mit einer Leitungsfunktion können für die Mitarbeiter*innen ihrer Organisation Zugangskonten erstellen. </Info>
		<Kapitel>Zugangskonto erstellen</Kapitel>
		<Schritt>Personaldatensatz öffnen</Schritt>


		<Info typ="Erklärung">Zugangskonten werden immer auf Basis der vorliegenden Personaldaten erstellt. Daher muss im ersten Schritt ein entsprechender Personaldatensatz ausgewählt werden.</Info>
		<Fragment name="neo-hauptmenue-personal-personalverwaltung"/>

		<Info typ="Erklärung">In diesem Beispiel filtern wir nur die Personaldatensätze, die noch kein Zugangskonto haben und öffnen den ersten Eintrag.</Info>

		<Click data-id="filters"/>
		<Click data-id="filters/basic/choose"/>
		<Click data-id="filters/basic/choose/b_exists"/>
		<Click data-id="filters/apply"/>
					
		<!-- erstes Element öffnen -->
		<Click data-id="list-item/0/toggleDetails"/>		
		<Click data-id="controlBtn/action-detaillinkwtitle"/>

		<Schritt>Zugangskontoerstellung auslösen</Schritt>
		<!-- Einstellungen öffnen zur Sichtbarkeit, dass noch kein Konto da ist-->
		<Click text="Einstellungen"/>
			

		<!-- zugangskonto erstellen -->
		<Click data-id="controlBtn/actions"/>
		<Click text="Zugangskonto anlegen"/>
		<Info typ="Erklärung">Die Zustellung der Zugangsdaten erfolgt über ein Zwei-Wege-Prinzip. Zum einen wird der Zugangsname über ein Funktionspostfach der Organisation übermittelt und zum anderen wird ein persönlicher Brief mit einem initialen Passwort über den Postweg über die Anschrift der Dienststelle zugestellt. Falls für die Person mehrere Dienststellen vorliegen, kann an dieser Stelle die adressierte Dienstelle ausgewählt werden.</Info>
		<Click text="Ja"/>
		<Info typ="Erklärung">Sobald beide Informationen der Person vorliegen, kann das Zugangskonto aktiviert werden.</Info>


	</Gruppe>

</SzenarioScript>
