<?xml version="1.0" encoding="UTF-8"?>
<SzenarioScript id="zugangsnamen-neu-zustellen" testscript-version="1" videoscript-version="1" confluence-page-id="2104459270" status="Entwurf" neo-version-min="6.0" neo-version-max="7.0" titel="Zugangsnamen neu zustellen">


	<Einstellungen>
		<Gruppe name="video">
			<Einstellung name="autoscroll_smooth" value="false"/>
			<Einstellung name="wait_between_steps" value="1000"/>
			<Gruppe name="resolution">
				<Einstellung name="width" value="1280"/>
				<Einstellung name="height" value="720"/>
			</Gruppe>
		</Gruppe>
		<Gruppe name="presentation">
			<Gruppe name="indicators">
				<Gruppe name="click">
					<Einstellung name="enabled" value="true"/>
					<Einstellung name="before_ms" value="100"/>
					<Einstellung name="after_ms" value="100"/>
					<Einstellung name="fade_ms" value="50"/>
				</Gruppe>
			</Gruppe>
		</Gruppe>
	</Einstellungen>

	<Daten>
		<Datensatz name="runtime">
			<Wert name="base_url" value="https://neo-test.de"/>
		</Datensatz>
		<Datensatz name="actor">
			<Wert name="username" value="schule_05320_schulleitung"/>
			<Wert name="password" value="!Neo-2405Neo!"/>
		</Datensatz>
	</Daten>

	<Gruppe>

		<Fragment name="neo-login">
			<Parameter name="url" value="{{runtime.base_url}}"/>
			<Parameter name="username" value="{{actor.username}}"/>
			<Parameter name="password" value="{{actor.password}}"/>
		</Fragment>
	</Gruppe>
	<Gruppe>

	<VideoStart/>
		<Info typ="Erklärung">Personen mit einer Leitungsfunktion können für die Mitarbeiter*innen ihrer Organisation den Zugangsnamen neu zustellen lassen. </Info>
		<Kapitel>Zugangsnamen neu zustellen</Kapitel>
		<Schritt>Personaldatensatz öffnen</Schritt>


		<Info typ="Erklärung">Zugangskonten sind in NEO Niedersachsen immer an einen Personaldatensatz gebunden. Daher muss im ersten Schritt ein entsprechender Personaldatensatz ausgewählt werden.</Info>

		<Fragment name="neo-hauptmenue-personal-personalverwaltung"/>


		<Info typ="Erklärung">In diesem Beispiel filtern wir nur die Personaldatensätze, die bereits ein Zugangskonto haben und öffnen den ersten Eintrag.</Info>

		<!-- Nur Personaldatensätze mit Konten anzeigen -->
		<Click data-id="filters"/>
		<Click data-id="filters/basic/choose"/>
		<Click data-id="filters/basic/choose/b_exists"/>
		<Click data-id="b_exists/b_exists" />
		<Click data-id="filters/apply"/>
	
		

		<!-- erstes elememt öffnen -->
		<Click data-id="list-item/0/toggleDetails"/>		
		<Click data-id="controlBtn/action-detaillinkwtitle"/>

		

		<Schritt>Erneute Zustellung des Zugangsnamens auslösen</Schritt>
		
		<!-- Einstellungen öffnen zur Sichtbarkeit, dass nich kein Konto da ist-->
		<Click text="Einstellungen"/>
		

		<!-- zugangskonto erstellen -->
		<Click data-id="controlBtn/actions"/>
		<Click text="Zugangsnamen erneut zustellen"/>		
		<Click text="Ja"/>		


	</Gruppe>

</SzenarioScript>
