<?xml version='1.0' encoding='UTF-8'?>
<SzenarioScript id="massnahme-genehmigen" szenario-version="1.0" status="Entwurf" neo-version-min="6.0">
	<Daten>
		<Datensatz name="runtime">
			<Wert name="base_url" value="https://neo-integration.de"/>
		</Datensatz>
		<Wert name="random" value="{{randomNumber()}}"/>
		<Datensatz name="actor">
      <!-- username=  ; Cindy Cantu; Start-Chancen-Berater von schule_05320_schulleitung  -->
			<Wert name="username" value="rggqjt4968"/>
			<Wert name="password" value="!Neo-2405Neo!"/>
		</Datensatz>		
	</Daten>
	<Variablen>
		<Variable name="random"/>
	</Variablen>

	<!-- Vorbereitung -->
	<Gruppe>
		<VideoStart/>
		<Kapitel>Zielvereinbarung erstellen</Kapitel>
		<Schritt>Einloggen</Schritt>
		<!-- Login -->
		<Fragment name="neo-login">
			<Parameter name="url" value="{{runtime.base_url}}"/>
			<Parameter name="username" value="{{actor.username}}"/>
			<Parameter name="password" value="{{actor.password}}"/>
		</Fragment>

    <!-- Aufgabe wahrnehmen und öffnen  -->
    <Click data-id="controlBtn/action-detaillink"/>

    <!--  Maßnhame ist geöffnet -->
    
    <Click data-id="controlBtn/actions"/>
    <Click text="Maßnahme genehmigen"/>
    <Click text="Ja"/>

    <VideoStop>
  </Gruppe>
</SzenarioScript

