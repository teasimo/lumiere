{
  "name": "lumiere-scenario-test-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:fragment-library": "node scripts/build-fragment-library.mjs",
    "generate:testscript": "node scripts/test-script-generator/generate-tests-from-scenario-xml.mjs",
    "generate:testscripts:all": "node scripts/test-script-generator/generate-tests-from-scenario-xml.mjs --all",
    "clean:testscripts": "node scripts/test-script-generator/generate-tests-from-scenario-xml.mjs --clean",
    "generate:testscript:xml": "node scripts/test-script-generator/generate-tests-from-scenario-xml.mjs",
    "generate:testscripts:xml:all": "node scripts/test-script-generator/generate-tests-from-scenario-xml.mjs --all",
    "clean:testscripts:xml": "node scripts/test-script-generator/generate-tests-from-scenario-xml.mjs --clean",
    "check:testscript": "node scripts/test-script-generator/run-generated-testfile.mjs --mode check",
    "check:testscript:verbose": "node scripts/test-script-generator/run-generated-testfile.mjs --mode check --verbose",
    "check:testscript:force": "node scripts/test-script-generator/run-generated-testfile.mjs --mode check --force",
    "run:testscript": "node scripts/test-script-generator/run-generated-testfile.mjs --mode video",
    "run:testscript:force": "node scripts/test-script-generator/run-generated-testfile.mjs --mode video --force",
    "run:speechscript": "node scripts/video-script-generator/run-annotated-video.mjs --scenario-tts --profile=all-channels",
    "run:speechscript:force": "node scripts/video-script-generator/run-annotated-video.mjs --scenario-tts --force-video --profile=all-channels",
    "generate:videoscript": "node scripts/video-script-generator/run-annotated-video.mjs --scenario-tts --profile=all-channels --remotion-plan-only",
    "run:videoscript": "LUMIERE_VIDEO_DEBUG_OVERLAY=0 node scripts/video-script-generator/remotion-render.mjs",
    "run:videoscript:debug": "LUMIERE_VIDEO_DEBUG_OVERLAY=1 node scripts/video-script-generator/remotion-render.mjs --keep-temp-project",
    "run:videoscript:verbose": "LUMIERE_VIDEO_DEBUG_OVERLAY=0 node scripts/video-script-generator/remotion-render.mjs --verbose",
    "debug:parse": "node scripts/debug-parse-scenario.mjs"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.1",
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "fast-xml-parser": "^4.5.6",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
